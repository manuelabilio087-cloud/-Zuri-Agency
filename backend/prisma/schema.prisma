generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum LeadStatus {
  NOVO
  CONTACTADO
  EM_NEGOCIACAO
  FECHADO
  PERDIDO
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  plan         Plan     @default(FREE)
  serviceType  String? // "Que tipo de serviço vende" - onboarding
  city         String? // localização de atuação - onboarding
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  leads         Lead[]
  usageLogs     UsageLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// Cache de empresas devolvidas pela Google Places API (janela de validade: 30 dias)
model Company {
  id            String   @id @default(uuid())
  placeId       String   @unique // Google Place ID
  name          String
  category      String
  address       String
  phone         String?
  website       String?
  rating        Float?
  reviewsCount  Int?
  city          String
  lastFetchedAt DateTime @default(now())

  analysis CompanyAnalysis?
  leads    Lead[]

  @@index([city, category])
  @@map("companies")
}

// Resultado da análise de maturidade digital (Website Score, SEO Score, Sales Score, Lead Temperature)
// Criado pelo módulo Website Analyzer + IA (próxima fase) — ainda não populado pelo módulo Companies.
model CompanyAnalysis {
  id                 String   @id @default(uuid())
  companyId          String   @unique
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  websiteScore       Int?
  seoScore           Int?
  salesScore         Int
  leadTemperature    String // frio | morno | quente | muito_quente
  recommendedService String
  closeProbability   Int
  scoreBreakdown     Json
  analyzedAt         DateTime @default(now())

  @@map("company_analyses")
}

// CRM: empresa guardada por um utilizador como lead
model Lead {
  id         String     @id @default(uuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status     LeadStatus @default(NOVO)
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([userId, companyId])
  @@map("leads")
}

// Log de uso para controlo de limites por plano (pesquisas, análises, gerações de IA)
model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String // "search" | "analysis" | "ai_generation"
  createdAt DateTime @default(now())

  @@index([userId, action, createdAt])
  @@map("usage_logs")
}
